<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--  Form View                                                        -->
    <record id="view_skynet_scanner_form" model="ir.ui.view">
        <field name="name">skynet.accessibility.scanner.form</field>
        <field name="model">x_odoo_skynetaccessibility_scanner</field>
        <field name="arch" type="xml">
            <form string="Skynet Accessibility Scanner" class="o_skynet_form">
            <link rel="stylesheet" href="/odoo_skynetaccessibility_scanner/static/src/css/skynet_scanner.css"/>
            <script src="/odoo_skynetaccessibility_scanner/static/src/js/skynet_scanner.js"></script>
            <sheet>
                    <div class="scanning-monitoring-app" id="skynetAppRoot">
             
                        <!--  LOADING OVERLAY                           -->
                        <div id="skynetLoading" class="skynet-loading-overlay">
                            <img src="/odoo_skynetaccessibility_scanner/static/src/img/assets/loader.gif"
                                 alt="Loading..." style="width:64px;height:64px;"/>
                            <p style="margin-top:12px;color:#420083;font-weight:500;">
                                Loading accessibility data...
                            </p>
                        </div>

                        <div id="skynetErrorBanner" class="skynet-error-banner" style="display:none;">
                            <span>Warning: </span>
                            <span id="skynetErrorMsg"></span>
                        </div>

                        <!--  SECTION 1 — MAIN DASHBOARD               -->
                        
                        <div id="skynetSection1" class="scans" style="display:none;">

                            <h2 class="title">My Scans</h2>

                            <!-- Status Row -->
                            <section class="status">
                                <div class="page-background"></div>

                                <div class="status-card" id="skynetScanScoreCard" style="cursor:pointer;">
                                    <span class="status-title">Scan Score</span>
                                    <div class="status-value" id="skynetScanScoreValue">
                                        <!-- Populated by JS -->
                                    </div>
                                </div>

                                <div class="status-card">
                                    <span class="status-title">Last Scanned</span>
                                    <div class="status-value" id="skynetLastScannedValue">
                                        <!-- Populated by JS -->
                                    </div>
                                </div>

                            </section>

                            <hr class="divider"/>

                            <!--
                                STATE: FREE / TRIAL PLAN
                                Condition: is_trial_period == 1 AND not expired AND not cancelled
                                  skynetFreePlanName   → "Free Plan"
                                  skynetFreePlanPages  → "Scan up to {pageViews} Pages"
                                  skynetFreePlanBadge  → "Current Plan"  (green #D1FFD3)
                                  skynetFreeExpiry     → "Expires on: {end_date}"  (red)
                                  skynetFreeActivateBtn → "Activate Now"  (purple #420083)
                            -->
                            <section id="skynetPlanFree" class="plan" style="display:none;">
                                <div class="page-background"></div>
                                <div class="plan-info">
                                    <div class="plans-left">
                                        <div class="plan-type free">
                                            <div class="icon-circle">
                                                <img src="/odoo_skynetaccessibility_scanner/static/src/img/assets/round.svg" alt="Round" height="20" width="20"/>
                                            </div>
                                            <span id="skynetFreePlanName">Free Plan</span>
                                        </div>
                                        <div class="plan-desc">
                                            <ul><li id="skynetFreePlanPages">Scan up to 10 Pages</li></ul>
                                        </div>
                                        <span class="plan-badge" id="skynetFreePlanBadge">Current Plan</span>
                                    </div>
                                    <div class="plans-right">
                                        <span class="plan-renewal" id="skynetFreeExpiry">
                                            Expires on: <strong>—</strong>
                                        </span>
                                        <span class="cancel-btn" id="skynetFreeActivateBtn" onclick="window._skynetBtnClick('free-activate', event)" style="cursor:pointer;">
                                            Activate Now
                                        </span>
                                    </div>
                                </div>
                            </section>

                            <!--
                                STATE: ACTIVE / PURCHASED PLAN
                                Condition: has activePackageId AND not trial AND not expired AND not cancelled
                                  skynetActivePlanName  → "{package_name} Plan"
                                  skynetActivePlanPages → "Scan up to {pageViews} Pages"
                                  skynetActivePlanBadge → "Current Plan"  (green #D1FFD3)
                                  skynetActiveRenewal   → "Renews on: {end_date}"
                                  skynetCancelSubBtn    → "Cancel Subscription"
                            -->
                            <section id="skynetPlanActive" class="plan" style="display:none;">
                                <div class="page-background"></div>
                                <div class="plan-info">
                                    <div class="plans-left">
                                        <div class="plan-type">
                                            <div class="icon-circle">
                                                <img src="/odoo_skynetaccessibility_scanner/static/src/img/assets/round.svg" alt="Round" height="20" width="20"/>
                                            </div>
                                            <span id="skynetActivePlanName"></span>
                                        </div>
                                        <div class="plan-desc">
                                            <ul><li id="skynetActivePlanPages"></li></ul>
                                        </div>
                                        <span class="plan-badge" id="skynetActivePlanBadge">Current Plan</span>
                                    </div>
                                    <div class="plans-right">
                                        <span class="plan-renewal" id="skynetActiveRenewal">
                                            Renews on: <strong>—</strong>
                                        </span>
                                        <span class="cancel-btn" id="skynetCancelSubBtn" onclick="window._skynetBtnClick('cancel-sub', event)" style="cursor:pointer;">
                                            Cancel Subscription
                                        </span>
                                    </div>
                                </div>
                            </section>

                            <!--
                                STATE: EXPIRED PLAN
                                Condition: is_expired == 1 OR end_date &lt; today
                                  skynetExpiredTitle       → "Your Plan has Expired"  (red #9F0000 bold)
                                  skynetExpiredDate        → ID is on the <span> wrapper (FIX 3).
                                                             JS injects full "Expired on: <strong>date</strong>"
                                                             so the label is never hardcoded + duplicated.
                                  skynetExpiredActivateBtn → "Renew Plan"  (purple #420083)
                                  Scan Score also shows N/A red in this state.
                            -->
                            <section id="skynetPlanExpired" class="plan" style="display:none;">
                                <div class="page-background"></div>
                                <div class="plan-info">
                                    <div class="plans-left">
                                        <div class="plan-type skynet-expired-title">
                                            <div class="icon-circle">
                                                <img src="/odoo_skynetaccessibility_scanner/static/src/img/assets/round.svg" alt="Round" height="20" width="20"/>
                                            </div>
                                            <span id="skynetExpiredTitle">Your Plan has Expired</span>
                                        </div>
                                    </div>
                                    <div class="plans-right">
                                        <!--
                                            FIX 3: id="skynetExpiredDate" moved from the inner <strong>
                                            to this <span> wrapper.  JS sets innerHTML on the <span>,
                                            injecting "Expired on: <strong>date</strong>" in full.
                                            Previously the id was on <strong>, so JS wrote
                                            "Expired on: <strong>date</strong>" inside it, producing
                                            nested <strong> tags and a doubled "Expired on:" label.
                                        -->
                                        <span class="plan-renewal" id="skynetExpiredDate">
                                            <!-- Populated by JS: "Expired on: <strong>date</strong>" -->
                                        </span>
                                        <span class="cancel-btn" id="skynetExpiredActivateBtn" onclick="window._skynetBtnClick('expired-renew', event)" style="background-color:#420083;color:#fff;cursor:pointer;">
                                            Renew Plan
                                        </span>
                                    </div>
                                </div>
                            </section>

                            <!--
                                STATE: CANCELLED PLAN
                                Condition: cancel_date &lt;= today AND not expired
                                  skynetCancelledPlanName  → "{package_name} Plan"
                                  skynetCancelledPlanPages → "Scan up to {pageViews} Pages"
                                  skynetCancelledPlanBadge → "Cancelled Plan"  (red #ffd1d1)
                                  skynetCancelledExpiry    → "Expires on: {end_date}"  (red)
                                  skynetRenewPlanBtn       → "Renew Plan"  (purple #420083)
                            -->
                            <section id="skynetPlanCancelled" class="plan" style="display:none;">
                                <div class="page-background"></div>
                                <div class="plan-info">
                                    <div class="plans-left">
                                        <div class="plan-type">
                                            <div class="icon-circle">
                                                <img src="/odoo_skynetaccessibility_scanner/static/src/img/assets/round.svg" alt="Round" height="20" width="20"/>
                                            </div>
                                            <span id="skynetCancelledPlanName"></span>
                                        </div>
                                        <div class="plan-desc">
                                            <ul><li id="skynetCancelledPlanPages"></li></ul>
                                        </div>
                                        <span class="plan-badge skynet-badge-cancelled" id="skynetCancelledPlanBadge">Cancelled Plan</span>
                                    </div>
                                    <div class="plans-right">
                                        <span class="plan-renewal" id="skynetCancelledExpiry">
                                            Expires on: <strong>—</strong>
                                        </span>
                                        <span class="cancel-btn" id="skynetRenewPlanBtn" onclick="window._skynetBtnClick('cancelled-renew', event)" style="background-color:#420083;color:#fff;cursor:pointer;">
                                            Renew Plan
                                        </span>
                                    </div>
                                </div>
                            </section>

                            <!-- Pricing Section -->
                            <section class="pricing">
                                <div class="page-background"></div>

                                <div class="billing-toggle">
                                    <span class="label active" id="monthly-label">Pay Monthly</span>
                                    <div class="switch">
                                        <!-- JS injects: <input type="checkbox" id="billing-toggle"/> -->
                                        <div id="skynetBillingToggleWrapper"></div>
                                        <span class="slider" id="skynetBillingSlider"></span>
                                    </div>
                                    <span class="label" id="annual-label">Pay Annually</span>
                                    <span class="save">Save 20%</span>
                                </div>

                                <div id="skynetMonthlyTiers" class="pricing-tiers">
                                </div>

                                <div id="skynetAnnualTiers" class="pricing-tiers" style="display:none;">
                                </div>

                                <p class="pricing-contact">
                                    Are you looking for a custom plan or Enterprise plan? Contact us
                                    <a href="mailto:hello@skynettechnologies.com">hello@skynettechnologies.com</a>
                                </p>
                            </section>

                            <!-- Help Section -->
                            <section class="help">
                                <p class="help-text">
                                    <strong>Facing any issues with Skynet Accessibility Scanner?</strong>
                                    Report a problem, we will get back to you very soon!
                                </p>
                                <a href="https://www.skynettechnologies.com/report-accessibility-problem"
                                   target="_blank" class="help-btn" role="button">
                                    Report a problem
                                </a>
                            </section>

                        </div><!-- end Section 1 -->

                        <!--  SECTION 2 — WCAG VIOLATION REPORT        -->
                        <div id="skynetSection2" class="accessibility-report" style="display:none;">

                            <div class="report-date">
                                <span style="font-weight:500;">Report Date:</span>
                                <span id="skynetS2ReportDate" style="border:1px solid #ccc;padding:8px 14px;border-radius:6px;font-weight:500;">—</span>
                            </div><br/>

                            <section class="top-section">

                                <div class="card score-card">
                                    <h3>Accessibility Score</h3>
                                    <div class="accessibility-score">
                                        <div class="score-value" id="skynetS2ScoreValue">0%</div>
                                        <span class="status-text not-compliant" id="skynetS2StatusText">Not Compliant</span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-fill" id="skynetS2ScoreBar" style="width:0%;"></div>
                                    </div>
                                    <p class="note">
                                        Automated Accessibility score has limitations.
                                        We recommend Manual Accessibility Audit.
                                    </p>
                                </div>

                                <div class="card pages-card">
                                    <h3>Web Pages Scanned</h3>
                                    <div class="pages-value" id="skynetS2PagesValue">0</div>
                                    <div class="progress-bar">
                                        <div class="progress-fill" id="skynetS2PagesBar" style="width:0%;"></div>
                                    </div>
                                    <p class="note" id="skynetS2PagesNote">0 pages scanned out of 0</p>
                                </div>

                            </section><br/><br/>

                            <section class="wcag-section">
                                <div class="wcag-header">
                                    <h3>WCAG 2.1/2.2</h3>
                                    <span class="view-btn" id="skynetS2ViewViolationsBtn" onclick="window._skynetBtnClick('view-violations', event)" style="cursor:pointer;">
                                        View all Violations
                                        <svg xmlns="http://www.w3.org/2000/svg" width="6" height="10" viewBox="0 0 6 10" fill="none">
                                            <path d="M6 5.00002C6 5.17924 5.92797 5.35843 5.78422 5.49507L1.25832 9.79486C0.970413 10.0684 0.503627 10.0684 0.21584 9.79486C-0.0719468 9.52145 -0.0719468 9.07807 0.21584 8.80452L4.22061 5.00002L0.21598 1.19549C-0.0718073 0.921968 -0.0718073 0.478632 0.21598 0.205242C0.503767 -0.0684128 0.970553 -0.0684128 1.25846 0.205242L5.78436 4.50496C5.92814 4.64166 6 4.82086 6 5.00002Z" fill="white"/>
                                        </svg>
                                    </span>
                                </div>

                                <div class="checks-grid">
                                    <div class="check-card failed">
                                        <span class="check-value" id="skynetS2FailedChecks">0</span>
                                        <span class="check-label">Failed Checks</span>
                                    </div>
                                    <div class="check-card passed">
                                        <span class="check-value" id="skynetS2PassedChecks">0</span>
                                        <span class="check-label">Passed Checks</span>
                                    </div>
                                    <div class="check-card na">
                                        <span class="check-value" id="skynetS2NAChecks">0</span>
                                        <span class="check-label">N/A Checks</span>
                                    </div>
                                </div>

                                <hr class="divider"/>

                                <div class="violations-grid">
                                    <div class="violation-card">
                                        <span class="violation-title">Level A</span>
                                        <span class="violation-count">
                                            <span id="skynetS2LevelA">0</span> violations
                                        </span>
                                    </div>
                                    <div class="violation-card">
                                        <span class="violation-title">Level AA</span>
                                        <span class="violation-count">
                                            <span id="skynetS2LevelAA">0</span> violations
                                        </span>
                                    </div>
                                    <div class="violation-card">
                                        <span class="violation-title">Level AAA</span>
                                        <span class="violation-count">
                                            <span id="skynetS2LevelAAA">0</span> violations
                                        </span>
                                    </div>
                                </div>

                            </section><br/><br/>

                            <span class="back-btn" id="skynetBackBtn" onclick="window._skynetBtnClick('back', event)" style="cursor:pointer;">Back</span>

                        </div><!-- end Section 2 -->

                    </div><!-- end scanning-monitoring-app -->
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_open_skynet_scanner" model="ir.actions.act_window">
    <field name="name">My Scans</field>
    <field name="res_model">x_odoo_skynetaccessibility_scanner</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
</record>

</odoo>